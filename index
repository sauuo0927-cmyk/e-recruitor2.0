function renderCalendar(){
  var el=document.getElementById('cal-grid'); if(!el)return;
  var days=['日','一','二','三','四','五','六'];
  var headers=days.map(function(d){return '<div style="font-size:11px;color:var(--color-text-tertiary);padding-bottom:6px">'+d+'</div>';}).join('');
  var today=7;
  var cells='';
  for(var i=0;i<28;i++){
    var d=i+1;
    var isToday=d===today;
    var hasEvent=d===8||d===9||d===10||d===11;
    cells+='<div style="padding:6px 4px;border-radius:var(--border-radius-md);'+(isToday?'background:var(--color-background-info);':hasEvent?'background:var(--color-background-success);':'')+'">';
    cells+='<div style="font-size:12px;font-weight:'+(isToday?'500':'400')+';color:'+(isToday?'var(--color-text-info)':hasEvent?'var(--color-text-success)':'var(--color-text-primary)')+'">'+d+'</div>';
    if(hasEvent) cells+='<div style="font-size:10px;color:var(--color-text-success);margin-top:2px">面試</div>';
    cells+='</div>';
  }
  el.innerHTML=headers+cells;
}

