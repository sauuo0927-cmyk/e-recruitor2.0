var pages={overview:'徵試總表',applicants:'應徵人選',candidates:'候選人選',interviews:'面試人選',results:'面試結果',hired:'任用人選',onboard:'新進員工',jobs:'職缺管理',calendar:'個人行事曆',stats:'招募績效分析',vip:'104 VIP 搜尋',talent:'人才庫',company:'公司管理 / 系統設定',accounts:'帳號設定',org:'組織設定',announce:'公告管理','job-apply':'職缺申請',messages:'聯絡訊息',blacklist:'黑名單',allresumes:'全部履歷'};
var currentPage='overview';

function showPage(page){
  if(document.getElementById('page-'+currentPage)) document.getElementById('page-'+currentPage).style.display='none';
  var el=document.getElementById('page-'+page);
  if(el) el.style.display='';
  currentPage=page;
  document.getElementById('page-title').textContent=pages[page]||page;
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active');});
  document.querySelectorAll('.nav-item').forEach(function(n){
    if(n.getAttribute('onclick')&&n.getAttribute('onclick').includes("'"+page+"'")) n.classList.add('active');
  });
  if(page==='overview') renderOverview();
  if(page==='applicants') renderApplicants();
  if(page==='candidates') renderCandidates();
  if(page==='interviews') renderInterviews();
  if(page==='results') renderResults();
  if(page==='hired') renderHired();
  if(page==='jobs') renderJobs();
  if(page==='accounts') renderAccounts();
  if(page==='onboard') renderOnboard();
  if(page==='stats') renderStats();
  if(page==='calendar') renderCalendar();
}

function openPanel(type, name){
  var pc=document.getElementById('panel-content');
  var ov=document.getElementById('overlay');
  var html='';
  if(type==='newJob'){
    html='<h3>申請新職缺</h3><div class="form-row"><label>職缺名稱</label><input type="text" placeholder="例：資深工程師"></div><div class="form-row"><label>所屬部門</label><select><option>技術部</option><option>產品部</option><option>設計部</option><option>行銷部</option></select></div><div class="form-row"><label>需求人數</label><input type="number" value="1" style="width:80px"></div><div class="form-row"><label>工作說明</label><textarea placeholder="請填寫職務內容說明..."></textarea></div><div class="form-row"><label>職缺需求說明</label><textarea placeholder="請填寫需求背景與說明..."></textarea></div><div class="form-btns"><button class="btn" onclick="closePanel()">取消</button><button class="btn btn-primary" onclick="closePanel()">送出申請</button></div>';
  } else if(type==='arrange'){
    html='<h3>安排面試</h3><div class="form-row"><label>面試名稱</label><input type="text" placeholder="例：一面技術面試"></div><div class="form-row"><label>面試日期時間</label><input type="datetime-local"></div><div class="form-row"><label>面試地點</label><input type="text" placeholder="例：B棟3F會議室"></div><div class="form-row"><label>面試官</label><input type="text" placeholder="例：陳主管"></div><div class="form-row"><label>面試方式</label><select><option>現場面試</option><option>視訊面試</option><option>電話面試</option></select></div><div class="form-row"><label>聯絡備註</label><textarea placeholder="其他注意事項..."></textarea></div><div class="form-row"><label>發送通知</label><select><option>求職者 + 面試官</option><option>僅求職者</option><option>僅面試官</option></select></div><div class="form-btns"><button class="btn" onclick="closePanel()">取消</button><button class="btn btn-primary" onclick="closePanel()">確認安排</button></div>';
  } else if(type==='hire'){
    html='<h3>申請任用</h3><div class="form-row"><label>錄取職缺</label><select><option>資深前端工程師</option><option>產品經理</option></select></div><div class="form-row"><label>報到日期</label><input type="date"></div><div class="form-row"><label>報到地點</label><input type="text" placeholder="例：台北總部 8F HR室"></div><div class="form-row"><label>薪資</label><input type="text" placeholder="可空白，待HR確認"></div><div class="form-row"><label>備註</label><textarea placeholder="其他說明..."></textarea></div><div class="form-btns"><button class="btn" onclick="closePanel()">取消</button><button class="btn btn-primary" onclick="closePanel()">送出申請</button></div>';
  } else if(type==='resume'){
    var n=name||'求職者';
    html='<h3>'+n+' 的履歷</h3><div style="display:flex;align-items:center;gap:12px;margin-bottom:14px"><div class="avatar" style="width:44px;height:44px;font-size:16px">'+n[0]+'</div><div><div style="font-weight:500;font-size:15px">'+n+'</div><div style="font-size:12px;color:var(--color-text-secondary)">資深前端工程師 應徵者</div></div></div><div style="border-top:0.5px solid var(--color-border-tertiary);padding-top:12px"><table style="width:100%;font-size:13px"><tr><td style="color:var(--color-text-secondary);padding:5px 0;width:80px">學歷</td><td>國立台灣大學資訊工程系</td></tr><tr><td style="color:var(--color-text-secondary);padding:5px 0">工作經歷</td><td>5年前端開發經驗</td></tr><tr><td style="color:var(--color-text-secondary);padding:5px 0">技能</td><td>React, Vue, TypeScript</td></tr><tr><td style="color:var(--color-text-secondary);padding:5px 0">期望薪資</td><td>70,000 - 90,000</td></tr></table></div><div style="margin-top:14px;display:flex;gap:8px"><button class="btn" onclick="closePanel()">關閉</button><button class="btn btn-primary" onclick="closePanel();openPanel(\'arrange\')">委託HR排面試</button></div>';
  } else if(type==='note'){
    var n=name||'求職者';
    html='<h3>填寫面談紀錄 — '+n+'</h3><div class="form-row"><label>到談狀況</label><select><option>已到談</option><option>未到談</option></select></div><div class="form-row"><label>面試結果</label><select><option>合格</option><option>不合格</option><option>待定</option></select></div><div class="form-row"><label>面談評語</label><textarea style="height:120px" placeholder="填寫詳細面談評語..."></textarea></div><div class="form-row"><label>評分 (1-100)</label><input type="number" value="80" min="1" max="100" style="width:80px"></div><div class="form-btns"><button class="btn" onclick="closePanel()">取消</button><button class="btn btn-primary" onclick="closePanel()">儲存記錄</button></div>';
  } else if(type==='newAccount'){
    html='<h3>新增帳號</h3><div class="form-row"><label>帳號</label><input type="text" placeholder="帳號名稱"></div><div class="form-row"><label>姓名</label><input type="text" placeholder="使用者姓名"></div><div class="form-row"><label>部門</label><select><option>人資部</option><option>技術部</option><option>產品部</option><option>設計部</option><option>行銷部</option></select></div><div class="form-row"><label>角色</label><select><option>HR</option><option>主管</option><option>Admin</option></select></div><div class="form-row"><label>Email</label><input type="email" placeholder="user@company.com"></div><div class="form-btns"><button class="btn" onclick="closePanel()">取消</button><button class="btn btn-primary" onclick="closePanel()">新增並發送密碼信</button></div>';
  }
  pc.innerHTML=html;
  ov.classList.add('show');
}

function closePanel(e){
  if(!e||e.target===document.getElementById('overlay')) document.getElementById('overlay').classList.remove('show');
}

renderOverview();
</script>
