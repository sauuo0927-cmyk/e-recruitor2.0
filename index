
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans);font-size:14px;color:var(--color-text-primary);background:var(--color-background-tertiary)}
.app{display:flex;height:100vh;min-height:600px}
.sidebar{width:200px;background:var(--color-background-primary);border-right:0.5px solid var(--color-border-tertiary);display:flex;flex-direction:column;flex-shrink:0}
.logo{padding:16px;border-bottom:0.5px solid var(--color-border-tertiary);font-weight:500;font-size:15px;color:var(--color-text-primary)}
.logo span{font-size:11px;color:var(--color-text-secondary);display:block;margin-top:2px}
.nav-section{padding:8px 0}
.nav-label{font-size:11px;color:var(--color-text-tertiary);padding:8px 16px 4px;letter-spacing:0.5px;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:8px;padding:7px 16px;cursor:pointer;font-size:13px;color:var(--color-text-secondary);border-radius:0;transition:background 0.1s;position:relative}
.nav-item:hover{background:var(--color-background-secondary);color:var(--color-text-primary)}
.nav-item.active{background:var(--color-background-info);color:var(--color-text-info);font-weight:500}
.nav-item .badge{margin-left:auto;background:var(--color-background-danger);color:var(--color-text-danger);font-size:10px;padding:1px 5px;border-radius:10px;font-weight:500}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{padding:12px 20px;background:var(--color-background-primary);border-bottom:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;gap:12px}
.topbar h2{font-size:15px;font-weight:500;flex:1}
.btn{padding:6px 14px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);background:transparent;color:var(--color-text-primary);font-size:13px;cursor:pointer}
.btn:hover{background:var(--color-background-secondary)}
.btn-primary{background:var(--color-background-info);color:var(--color-text-info);border-color:var(--color-border-info)}
.content{flex:1;overflow-y:auto;padding:16px 20px}
.stats-row{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:16px}
.stat-card{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:12px;text-align:center;cursor:pointer;border:0.5px solid transparent;transition:border 0.15s}
.stat-card:hover{border-color:var(--color-border-secondary)}
.stat-card.active{border-color:var(--color-border-info);background:var(--color-background-info)}
.stat-card .num{font-size:22px;font-weight:500;line-height:1.2}
.stat-card .lbl{font-size:11px;color:var(--color-text-secondary);margin-top:3px}
.stat-card.active .lbl{color:var(--color-text-info)}
.filter-bar{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.filter-bar input,.filter-bar select{padding:6px 10px;border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-md);background:var(--color-background-primary);color:var(--color-text-primary);font-size:13px}
.table-wrap{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);overflow:hidden}
table{width:100%;border-collapse:collapse;font-size:13px}
th{padding:10px 12px;text-align:left;font-weight:500;color:var(--color-text-secondary);border-bottom:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary);font-size:12px}
td{padding:10px 12px;border-bottom:0.5px solid var(--color-border-tertiary);color:var(--color-text-primary)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--color-background-secondary)}
.tag{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:500}
.tag-new{background:var(--color-background-info);color:var(--color-text-info)}
.tag-pending{background:var(--color-background-warning);color:var(--color-text-warning)}
.tag-pass{background:var(--color-background-success);color:var(--color-text-success)}
.tag-fail{background:var(--color-background-danger);color:var(--color-text-danger)}
.tag-hired{background:#e9f5e9;color:#2e7d32}
.action-btns{display:flex;gap:4px}
.action-btns button{padding:3px 8px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);background:transparent;color:var(--color-text-secondary);font-size:11px;cursor:pointer}
.action-btns button:hover{background:var(--color-background-secondary);color:var(--color-text-primary)}
.panel-overlay{display:none;position:absolute;inset:0;background:rgba(0,0,0,0.3);z-index:50;align-items:center;justify-content:center}
.panel-overlay.show{display:flex}
.panel{background:var(--color-background-primary);border-radius:var(--border-radius-lg);border:0.5px solid var(--color-border-tertiary);padding:20px;width:480px;max-height:80vh;overflow-y:auto}
.panel h3{font-size:15px;font-weight:500;margin-bottom:14px;padding-bottom:10px;border-bottom:0.5px solid var(--color-border-tertiary)}
.form-row{margin-bottom:12px}
.form-row label{display:block;font-size:12px;color:var(--color-text-secondary);margin-bottom:4px}
.form-row input,.form-row select,.form-row textarea{width:100%;padding:7px 10px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);background:var(--color-background-primary);color:var(--color-text-primary);font-size:13px}
.form-row textarea{height:80px;resize:vertical}
.form-btns{display:flex;gap:8px;justify-content:flex-end;margin-top:16px}
.tabs{display:flex;gap:0;border-bottom:0.5px solid var(--color-border-tertiary);margin-bottom:16px}
.tab{padding:8px 16px;font-size:13px;cursor:pointer;color:var(--color-text-secondary);border-bottom:2px solid transparent;margin-bottom:-1px}
.tab.active{color:var(--color-text-info);border-bottom-color:var(--color-border-info);font-weight:500}
.empty{text-align:center;padding:40px;color:var(--color-text-tertiary);font-size:13px}
.score-bar{width:60px;height:6px;background:var(--color-border-tertiary);border-radius:3px;display:inline-block;vertical-align:middle;position:relative;overflow:hidden}
.score-fill{height:100%;border-radius:3px;background:var(--color-background-success)}
.memo-dot{width:8px;height:8px;border-radius:50%;background:var(--color-background-warning);display:inline-block}
.pipeline-row{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-bottom:16px;background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);overflow:hidden}
.pipe-col{padding:12px;text-align:center;border-right:0.5px solid var(--color-border-tertiary);cursor:pointer}
.pipe-col:last-child{border-right:none}
.pipe-col:hover{background:var(--color-background-secondary)}
.pipe-col .pnum{font-size:20px;font-weight:500;color:var(--color-text-info)}
.pipe-col .plbl{font-size:11px;color:var(--color-text-secondary);margin-top:2px}
.avatar{width:28px;height:28px;border-radius:50%;background:var(--color-background-info);color:var(--color-text-info);display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:500}
.page-wrap{position:relative}
</style>

